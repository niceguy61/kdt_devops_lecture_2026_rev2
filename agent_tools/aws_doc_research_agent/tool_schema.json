{
  "tools": [
    {
      "name": "search_aws_docs",
      "description": "Search AWS documentation and return normalized candidate sources.",
      "input_schema": {
        "type": "object",
        "properties": {
          "query": { "type": "string" },
          "limit": { "type": "integer", "minimum": 1, "maximum": 50 },
          "product_types": { "type": "array", "items": { "type": "string" } },
          "guide_types": { "type": "array", "items": { "type": "string" } },
          "search_intent": { "type": "string" }
        },
        "required": ["query"]
      }
    },
    {
      "name": "read_aws_doc",
      "description": "Read and compact a docs.aws.amazon.com HTML documentation page.",
      "input_schema": {
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "max_chars": { "type": "integer", "minimum": 1 },
          "start_index": { "type": "integer", "minimum": 0 }
        },
        "required": ["url"]
      }
    },
    {
      "name": "make_citation_pack",
      "description": "Build a lecture-ready AWS documentation citation pack.",
      "input_schema": {
        "type": "object",
        "properties": {
          "topic": { "type": "string" },
          "audience": { "type": "string" },
          "limit": { "type": "integer", "minimum": 1, "maximum": 20 }
        },
        "required": ["topic"]
      }
    }
  ]
}

